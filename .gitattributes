# Normalize text files to LF in the repo (stops the CRLF churn on Windows).
* text=auto eol=lf

# Binary assets — never apply end-of-line conversion (prevents corruption,
# e.g. the Raspberry Pi logo / sensor images failing to load after checkout).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.onnx binary
*.hef binary
*.ort binary
*.bin binary
*.pt binary
*.npy binary
*.npz binary
