# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Local Intel NPU Level Zero driver extract (large; not committed)
.npu_driver/

# Demo outputs (regenerated on every run)
outputs/

# Compact cloud kit is committed (checkpoints + npz pairs; no DNGs)
!cloud_pack/
!cloud_pack/**

# Real-capture datasets — large DNG trees stay local; sample PNGs may be committed
datasets/**/*.dng
datasets/**/*.raw
third_party/
.tmp/

# Frozen Hugging Face snapshots (pinned model weights, can be large)
models/frozen/
models/noise/*.json
models/noise/*.validation.json

# Remembered GUI wizard settings (per-machine, not shared)
.nsa_gui_state.json

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
